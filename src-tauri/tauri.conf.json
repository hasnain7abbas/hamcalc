{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HamCalc",
  "version": "0.1.1",
  "identifier": "app.hamcalc",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HamCalc — Symbolic Hamiltonian Solver",
        "width": 1280,
        "height": 840,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "publisher": "HamCalc",
    "category": "Education",
    "shortDescription": "Symbolic Hamiltonian Solver",
    "longDescription": "Diagonalize matrix Hamiltonians with symbolic and numeric eigenvalues, eigenvectors, characteristic polynomial, and time-evolution operator.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": [
          "en-US"
        ]
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine"
      }
    }
  }
}
